<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Toolbar -->
    <include
        layout="@layout/partial_primary_toolbar"
        android:id="@+id/partial_primary_toolbar" />

    <!-- Breadcrumb navigation area -->
    <LinearLayout
        android:id="@+id/breadcrumb_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/morandi_breadcrumb_background"
        android:gravity="start|center_vertical">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_new_session"
            android:background="@null"
            android:contentDescription="@string/back_to_parent_directory"
            android:rotation="180" />

        <!-- Breadcrumb path display -->
        <HorizontalScrollView
            android:id="@+id/breadcrumb_scroll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/breadcrumb_path_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="start|center_vertical">

                <!-- Breadcrumb segments will be added dynamically -->
            </LinearLayout>
        </HorizontalScrollView>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?android:attr/listDivider" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/loading_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminate="true"
        android:padding="16dp" />

    <!-- File list -->
    <ListView
        android:id="@+id/file_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:choiceMode="singleChoice"
        android:longClickable="true"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:fastScrollEnabled="true"
        tools:listitem="@layout/item_remote_file" />

    <!-- Empty state view -->
    <TextView
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/empty_directory"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- Bottom action bar -->
    <LinearLayout
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/new_folder_button"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/action_new_folder" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/upload_button"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/action_upload" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/refresh_button"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/action_refresh" />

    </LinearLayout>

</LinearLayout>