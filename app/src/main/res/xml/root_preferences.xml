<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <Preference
        app:key="openclaw"
        app:title="@string/openclaw_preferences_title"
        app:summary="@string/openclaw_preferences_summary"
        app:fragment="com.termux.app.fragments.settings.TermuxPreferencesFragment"/>

    <Preference
        app:key="ai_settings"
        app:title="AI Settings"
        app:summary="Configure OpenClaw and Ollama"
        app:fragment="com.termux.app.fragments.settings.AISettingsFragment"/>

    <Preference
        app:key="openclaw_api"
        app:title="@string/openclaw_api_preferences_title"
        app:summary="@string/openclaw_api_preferences_summary"
        app:isPreferenceVisible="false"
        app:fragment="com.termux.app.fragments.settings.TermuxAPIPreferencesFragment"/>

    <Preference
        app:key="openclaw_float"
        app:title="@string/openclaw_float_preferences_title"
        app:summary="@string/openclaw_float_preferences_summary"
        app:isPreferenceVisible="false"
        app:fragment="com.termux.app.fragments.settings.TermuxFloatPreferencesFragment"/>

    <Preference
        app:key="openclaw_tasker"
        app:title="@string/openclaw_tasker_preferences_title"
        app:summary="@string/openclaw_tasker_preferences_summary"
        app:isPreferenceVisible="false"
        app:fragment="com.termux.app.fragments.settings.TermuxTaskerPreferencesFragment"/>

    <Preference
        app:key="openclaw_widget"
        app:title="@string/openclaw_widget_preferences_title"
        app:summary="@string/openclaw_widget_preferences_summary"
        app:isPreferenceVisible="false"
        app:fragment="com.termux.app.fragments.settings.TermuxWidgetPreferencesFragment"/>

    <Preference
        app:key="about"
        app:title="@string/about_preference_title"
        app:persistent="false"/>
    <!-- app:layout="@layout/preference_markdown_text" -->

    <Preference
        app:key="donate"
        app:title="@string/donate_preference_title"
        app:persistent="false"
        app:isPreferenceVisible="false"/>

</PreferenceScreen>
