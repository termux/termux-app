<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Morandi Theme Colors for Remote File Browser (Light Mode) -->
    <!-- Semantic color names for file manager components -->

    <!-- Primary palette - Using Sage Green as primary brand color -->
    <color name="morandi_primary">@color/morandi_sage_green</color>
    <color name="morandi_primary_variant">@color/morandi_sage_green_dark</color>
    <color name="morandi_primary_light">@color/morandi_sage_green_light</color>

    <!-- Secondary palette - Using Muted Blue for secondary actions -->
    <color name="morandi_secondary">@color/morandi_muted_blue</color>
    <color name="morandi_secondary_variant">@color/morandi_muted_blue_dark</color>

    <!-- Background colors - Cream and soft whites for light mode -->
    <color name="morandi_background">@color/morandi_cream</color>
    <color name="morandi_background_variant">#F8F5EA</color>  <!-- Very light cream -->
    <color name="morandi_surface">#FFFFFF</color>            <!-- White surface for cards/dialogs -->
    <color name="morandi_surface_variant">#F5F2E8</color>    <!-- Slightly warm surface -->

    <!-- Text colors - Charcoal and Stone for readability -->
    <color name="morandi_text_primary">@color/morandi_charcoal</color>
    <color name="morandi_text_secondary">@color/morandi_stone</color>
    <color name="morandi_text_tertiary">@color/morandi_ash</color>
    <color name="morandi_text_hint">@color/morandi_warm_grey</color>

    <!-- File browser specific semantic colors -->
    <color name="morandi_directory_name">@color/morandi_sage_green</color>
    <color name="morandi_directory_icon">@color/morandi_sage_green_light</color>
    <color name="morandi_file_name">@color/morandi_charcoal</color>
    <color name="morandi_file_icon">@color/morandi_stone</color>
    <color name="morandi_file_size">@color/morandi_warm_grey</color>
    <color name="morandi_file_modified">@color/morandi_ash</color>
    <color name="morandi_symlink_name">@color/morandi_muted_blue</color>
    <color name="morandi_hidden_file_name">@color/morandi_taupe</color>

    <!-- Breadcrumb navigation colors -->
    <color name="morandi_breadcrumb_background">@color/morandi_background_variant</color>
    <color name="morandi_breadcrumb_text">@color/morandi_text_secondary</color>
    <color name="morandi_breadcrumb_current">@color/morandi_primary</color>
    <color name="morandi_breadcrumb_separator">@color/morandi_stone</color>

    <!-- Action and state colors -->
    <color name="morandi_selected_background">@color/morandi_mist</color>
    <color name="morandi_selected_text">@color/morandi_charcoal</color>
    <color name="morandi_pressed_background">@color/morandi_sage_green_light</color>
    <color name="morandi_focused_background">@color/morandi_dusty_rose_light</color>

    <!-- Divider and border colors -->
    <color name="morandi_divider">@color/morandi_sand</color>
    <color name="morandi_border">@color/morandi_pebble</color>
    <color name="morandi_border_light">#E0DCCF</color>

    <!-- Icon colors -->
    <color name="morandi_icon_primary">@color/morandi_stone</color>
    <color name="morandi_icon_active">@color/morandi_primary</color>
    <color name="morandi_icon_disabled">@color/morandi_ash</color>

    <!-- Error and warning colors (subtle Morandi variants) -->
    <color name="morandi_error">@color/morandi_dusty_rose</color>
    <color name="morandi_error_background">#F5E5E5</color>
    <color name="morandi_warning">@color/morandi_clay</color>
    <color name="morandi_warning_background">#F5EEC8</color>
    <color name="morandi_success">@color/morandi_moss</color>
    <color name="morandi_success_background">#E8F0E8</color>

    <!-- Status bar and navigation bar -->
    <color name="morandi_status_bar">@color/morandi_sage_green_dark</color>
    <color name="morandi_navigation_bar">@color/morandi_background_variant</color>

    <!-- Floating action button -->
    <color name="morandi_fab_background">@color/morandi_primary</color>
    <color name="morandi_fab_icon">@color/morandi_cream</color>

    <!-- Toolbar and app bar -->
    <color name="morandi_toolbar_background">@color/morandi_cream</color>
    <color name="morandi_toolbar_text">@color/morandi_text_primary</color>
    <color name="morandi_toolbar_icon">@color/morandi_icon_primary</color>
</resources>